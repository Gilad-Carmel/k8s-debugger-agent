# ---------------------------------------------------------------------------
# .env — local dev overrides (not committed, see .gitignore)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# LLM provider — local OpenAI-compatible inference server
# Server: LM Studio (or compatible) at localhost:52984
# Model:  IBM Granite 3.3 8B Instruct (GGUF)
# ---------------------------------------------------------------------------
LLM_BASE_URL=http://localhost:52984/v1
LLM_API_KEY=lm-studio
LLM_ROUTER_MODEL=/models/hf.ibm-granite.granite-3.3-8b-instruct-GGUF
LLM_EXPERT_MODEL=/models/hf.ibm-granite.granite-3.3-8b-instruct-GGUF

# ---------------------------------------------------------------------------
# Per-incident budget  (spec FR-029)
# ---------------------------------------------------------------------------
BUDGET_TOKENS_PER_INCIDENT=50000
BUDGET_USD_MICROS_PER_INCIDENT=-1

# ---------------------------------------------------------------------------
# Webhook HMAC secret  (spec FR-002)
# MUST be changed in non-dev environments.
# ---------------------------------------------------------------------------
ALERTMANAGER_HMAC_SECRET=dev-secret-change-me

# ---------------------------------------------------------------------------
# Mock-Slack settings  (research.md R6)
# ---------------------------------------------------------------------------
SLACK_MOCK_SECRET=dev-slack-secret
SLACK_MOCK_URL=http://localhost:9000

# ---------------------------------------------------------------------------
# HITL approval window  (spec FR-017) — default 30 minutes
# ---------------------------------------------------------------------------
APPROVAL_WINDOW_SECONDS=1800
