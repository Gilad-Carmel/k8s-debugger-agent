# ---------------------------------------------------------------------------
# .env.example — copy to .env and adjust before running the agent locally
#
# All values here are safe defaults for a local Ollama dev environment.
# DO NOT commit a .env file with real secrets — .gitignore excludes it.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# LLM provider — local OpenAI-compatible inference server
# (plan.md §Technical Context, research.md R2)
#
# Default: Ollama running on localhost.  Start with:
#   ollama serve                     # starts the server
#   ollama pull qwen2.5:7b           # pull the router model
#   ollama pull qwen2.5:14b          # pull the expert model
#
# For LM Studio: set LLM_BASE_URL=http://localhost:1234/v1
# For cloud OpenAI: set LLM_BASE_URL=https://api.openai.com/v1 and a real key
# ---------------------------------------------------------------------------
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_ROUTER_MODEL=qwen2.5:7b
LLM_EXPERT_MODEL=qwen2.5:14b

# ---------------------------------------------------------------------------
# Per-incident budget  (spec FR-029)
# For local inference USD cost is not metered; set -1 for unlimited.
# Token ceiling is always enforced fail-closed.
# ---------------------------------------------------------------------------
BUDGET_TOKENS_PER_INCIDENT=50000
BUDGET_USD_MICROS_PER_INCIDENT=-1

# ---------------------------------------------------------------------------
# Webhook HMAC secret  (spec FR-002)
# MUST be changed in non-dev environments.
# ---------------------------------------------------------------------------
ALERTMANAGER_HMAC_SECRET=dev-secret-change-me

# ---------------------------------------------------------------------------
# Mock-Slack settings  (research.md R6)
# ---------------------------------------------------------------------------
SLACK_MOCK_SECRET=dev-slack-secret
SLACK_MOCK_URL=http://localhost:9000

# ---------------------------------------------------------------------------
# HITL approval window  (spec FR-017) — default 30 minutes
# ---------------------------------------------------------------------------
APPROVAL_WINDOW_SECONDS=1800
