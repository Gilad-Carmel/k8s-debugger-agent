# deploy/Dockerfile.mcp
#
# MCP server: separate process exposing Kubernetes read + scoped-write tools.
#
# Physically separate from the agent so the agent process never holds a
# write-capable kube token (research.md R5, Principle I).
#
# Memory budget: ≤ 256 MiB RSS (plan.md §Constraints, Principle IX)
# Exposed port  : 8081 (HTTP/SSE transport in prod; stdio in dev)
# Entry point   : python -m src.mcp_server  (src/mcp_server/__main__.py)
#
# Build from repo root:
#   docker build -f deploy/Dockerfile.mcp -t k8s-debugger-mcp .

FROM python:3.11-slim AS base

WORKDIR /app

# ---- dependency layer --------------------------------------------------------
COPY pyproject.toml .
RUN pip install --no-cache-dir uv==0.6.14

# Install runtime deps only.
RUN uv pip install --system --no-cache .

# ---- source layer ------------------------------------------------------------
COPY src/ src/

# ---- runtime image -----------------------------------------------------------
FROM base AS runtime

# Non-root user per Principle I (least privilege).
RUN useradd --no-create-home --shell /bin/false mcp
USER mcp

# Per-tool Kubernetes ServiceAccount tokens are mounted here by the compose
# stack (or by the k8s pod spec in production).
# The MCP server loads them at startup via src/mcp_server/auth.py.
ENV MCP_SA_TOKEN_DIR=/run/secrets/mcp-sa \
    MCP_TRANSPORT=http \
    MCP_HOST=0.0.0.0 \
    MCP_PORT=8081 \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

EXPOSE 8081

CMD ["python", "-m", "src.mcp_server"]
